{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/reviews", "destination": "/reviews.html" },
    { "source": "/expertise", "destination": "/expertise.html" },
    { "source": "/community", "destination": "/community.html" },
    { "source": "/professionals", "destination": "/professionals.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/post", "destination": "/blog/post.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
